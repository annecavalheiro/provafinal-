#include <stdio.h>
#include <stdlib.h>
#include <string.h>

typedef enum { INATIVO = 0, NORMAL, FAVORITO, BLOQUEADO } Status;

typedef struct {
    char rua[50]; // CORRIGIDO: de char para vetor
    int numero;
} Endereco;

typedef struct {
    int id;
    char nome[50];     // CORRIGIDO: de char para vetor
    char telefone[20]; // CORRIGIDO: de char para vetor
    Endereco end; 
    Status status;
} Contato;

// --- PROTÓTIPOS OBRIGATÓRIOS ---
void lerTxt(char *msg, char *v, int t);
void salvar();
void carregar();
void cadastrar();

// Ponteiro global e contadores
Contato *ag = NULL;
int tot = 0, proxId = 1;

int main() {
    int op, id, pos;
    
    carregar(); // Carrega os dados assim que o programa inicia

    do {
        printf("\n1-Add 2-Listar 3-Buscar 4-Edit Fone 5-Remover 0-Sair\nOpcao: ");
        if (scanf("%d", &op) != 1) op = -1;
        getchar(); // Limpa o buffer do teclado

        if(op == 1) cadastrar();
        
        else if(op == 2) {
            printf("\n--- CONTATOS ATIVOS ---\n");
            for(int i = 0; i < tot; i++)
                if(ag[i].status != INATIVO) 
                    printf("ID: %d | %s | %s\n", ag[i].id, ag[i].nome, ag[i].telefone);
        }
        
        else if(op == 3 || op == 4 || op == 5) {
            printf("ID do Contato: "); scanf("%d", &id); getchar();
            pos = -1;
            for(int i = 0; i < tot; i++) {
                if(ag[i].id == id && ag[i].status != INATIVO) { pos = i; break; }
            }
            
            if(pos == -1) {
                printf("Nao encontrado.\n");
            } else {
                if(op == 3) printf("Nome: %s | Fone: %s | Rua: %s, %d\n", ag[pos].nome, ag[pos].telefone, ag[pos].end.rua, ag[pos].end.numero);
                else if(op == 4) { lerTxt("Novo Fone: ", ag[pos].telefone, 20); salvar(); printf("Atualizado!\n"); }
                else if(op == 5) { ag[pos].status = INATIVO; salvar(); printf("Removido logicamente!\n"); }
            }
        }
    } while(op != 0);

    free(ag); // Libera a memoria alocada antes de fechar
    return 0;
}

// --- IMPLEMENTAÇÃO ---

void lerTxt(char *msg, char *v, int t) {
    printf("%s", msg);
    fgets(v, t, stdin);
    v[strcspn(v, "\n")] = '\0';
}

void salvar() {
    FILE *f = fopen("agenda.txt", "w");
    if(!f) return;
    fprintf(f, "%d;%d\n", tot, proxId); 
    for(int i = 0; i < tot; i++) {
        fprintf(f, "%d;%s;%s;%s;%d;%d\n", ag[i].id, ag[i].nome, ag[i].telefone, 
                ag[i].end.rua, ag[i].end.numero, ag[i].status);
    }
    fclose(f);
}

void carregar() {
    FILE *f = fopen("agenda.txt", "r");
    if(!f) return;
    if (fscanf(f, "%d;%d\n", &tot, &proxId) != 2) { fclose(f); return; }
    
    ag = malloc(tot * sizeof(Contato)); 
    if(!ag && tot > 0) { fclose(f); return; }

    for(int i = 0; i < tot; i++) {
        int st;
        // %49[^;] lê até 49 caracteres ou encontrar ';'
        fscanf(f, "%d;%49[^;];%19[^;];%49[^;];%d;%d\n", &ag[i].id, ag[i].nome, 
               ag[i].telefone, ag[i].end.rua, &ag[i].end.numero, &st);
        ag[i].status = (Status)st;
    }
    fclose(f);
}

void cadastrar() {
    Contato *temp = realloc(ag, (tot + 1) * sizeof(Contato));
    if (!temp) {
        printf("Erro de alocacao de memoria!\n");
        return;
    }
    ag = temp;

    ag[tot].id = proxId++;
    ag[tot].status = NORMAL;

    printf("\n--- NOVO CONTATO (ID: %d) ---\n", ag[tot].id);
    lerTxt("Nome: ", ag[tot].nome, 50);
    lerTxt("Telefone: ", ag[tot].telefone, 20);
    lerTxt("Rua: ", ag[tot].end.rua, 50);
    printf("Numero: "); scanf("%d", &ag[tot].end.numero); getchar();

    tot++;
    salvar(); 
    printf("Contato salvo com sucesso!\n");
}
